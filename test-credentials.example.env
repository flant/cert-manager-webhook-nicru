#!/bin/bash
# =======================================================
# Example credentials for NIC.RU Integration Tests
# =======================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp test-credentials.example.env test-credentials.env
# 2. Edit test-credentials.env with your REAL NIC.RU credentials
# 3. Load variables: source test-credentials.env
# 4. Run tests: go test -v -tags=integration ./tests/integration/
#
# SECURITY WARNING:
# - NEVER commit test-credentials.env to git!
# - File test-credentials.env is in .gitignore
# - Only commit this example file
#
# =======================================================

# NIC.RU account username (your login)
export NICRU_USERNAME="your-nic-ru-username"

# NIC.RU account password
export NICRU_PASSWORD="your-nic-ru-password"

# OAuth 2.0 Application Client ID
# Get from: https://www.nic.ru/manager/oauth.cgi?step=oauth.app.list
export NICRU_CLIENT_ID="your-oauth-client-id"

# OAuth 2.0 Application Client Secret
export NICRU_CLIENT_SECRET="your-oauth-client-secret"

# DNS zone for integration testing (REQUIRED for DNS tests)
# IMPORTANT: Tests will CREATE and DELETE TXT records in this zone!
# Example: "test.example.com" or "staging.mysite.ru"
# Recommendation: Use a dedicated test zone, NOT production!
export NICRU_TEST_ZONE="your-test-zone.com"

# =======================================================
# How to use:
# =======================================================
#
# cd /path/to/cert-manager-webhook-nicru
# cp test-credentials.example.env test-credentials.env
# vim test-credentials.env  # Edit with real values
# source test-credentials.env
#
# IMPORTANT: Set NICRU_TEST_ZONE to a safe test domain!
# DNS tests will create/delete records in this zone.
#
# go test -v -tags=integration ./tests/integration/
#
# =======================================================
